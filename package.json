{
  "name": "ninja-agents",
  "displayName": "Ninja Village",
  "description": "Animated ninja sidebar that visualizes Claude Code agent activity in real-time",
  "version": "0.1.0",
  "publisher": "ninja-village",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Visualization"],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ninjaAgents",
          "title": "Ninja Village",
          "icon": "media/ninja.svg"
        }
      ]
    },
    "views": {
      "ninjaAgents": [
        {
          "type": "webview",
          "id": "ninjaAgents.ninjaPanel",
          "name": "Ninja Village"
        }
      ]
    },
    "commands": [
      {
        "command": "ninjaAgents.triggerDemo",
        "title": "Ninja Agents: Trigger Demo"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
